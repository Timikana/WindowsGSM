                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
            </Grid>
            <Grid x:Name="MahAppFlyout_Settings" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="640" MaxHeight="740" CornerRadius="8" Padding="8" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,4">
                        <ui:ToggleSwitch x:Name="MahAppSwitch_HardWareAcceleration" Content="{loc:Tr MW.Settings.HardwareAcceleration}" Margin="20,10,0,15" Click="HardWareAcceleration_IsCheckedChanged"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_UIAnimation" Content="{loc:Tr MW.Settings.UIAnimation}" Margin="20,0,0,15" Click="UIAnimation_IsCheckedChanged"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_DarkTheme" Content="{loc:Tr MW.Settings.DarkTheme}" Margin="20,0,0,15" Click="DarkTheme_IsCheckedChanged"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_StartOnBoot" Content="{loc:Tr MW.Settings.StartOnLogin}" Margin="20,0,0,15" Click="StartOnLogin_IsCheckedChanged"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_RestartOnCrash" Content="{loc:Tr MW.Settings.RestartOnCrash}" Margin="20,0,0,15" Click="RestartOnCrash_IsCheckedChanged"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_SendStatistics" Content="{loc:Tr MW.Settings.SendStatistics}" Margin="20,0,0,15" Click="SendStatistics_IsCheckedChanged"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_DonorConnect" Content="{loc:Tr MW.Settings.DonorConnect}" Margin="20,0,0,15" Click="DonorConnect_IsCheckedChanged"/>
                        <DockPanel Margin="20,0,20,20">
                            <Label Content="{loc:Tr MW.Settings.ThemeDonorOnly}" FontSize="13.5" Padding="0" DockPanel.Dock="Top"></Label>
                            <ComboBox x:Name="comboBox_Themes" Margin="0,5,0,0" MinHeight="32" Padding="10,4" DockPanel.Dock="Top" SelectionChanged="ComboBox_Themes_SelectionChanged" IsEnabled="False"></ComboBox>
                        </DockPanel>
                        <DockPanel Margin="20,0,20,20">
                            <Label Content="Language / Langue" FontSize="13.5" Padding="0" DockPanel.Dock="Top"></Label>
                            <ComboBox x:Name="comboBox_Language" Margin="0,5,0,0" MinHeight="32" Padding="10,4" DockPanel.Dock="Top" SelectionChanged="ComboBox_Language_SelectionChanged"></ComboBox>
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            </Grid>
            <Grid x:Name="MahAppFlyout_DiscordAlert" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="560" MaxHeight="600" CornerRadius="8" Padding="20" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <DockPanel MinWidth="380">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="3" Height="18" CornerRadius="2" Background="#4CC2D6" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <ui:SymbolIcon Symbol="Alert24" FontSize="18" Foreground="#4CC2D6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{loc:Tr MW.Alert.Title}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Tr MW.Alert.Hint}" TextWrapping="Wrap" Opacity="0.7" Margin="13,0,0,14"/>
                    <Button DockPanel.Dock="Bottom" Content="{loc:Tr MW.Common.Close}" Click="DiscordAlert_Close_Click" HorizontalAlignment="Right" MinWidth="90" Padding="14,4" Margin="0,14,0,0"/>
                    <Border CornerRadius="6" Padding="16,8" Background="{ui:ThemeResource ControlFillColorSecondaryBrush}">
                        <StackPanel>
                            <ui:ToggleSwitch x:Name="MahAppSwitch_AutoStartAlert" Content="{loc:Tr MW.Alert.AutoStart}" Margin="0,7" Click="Switch_AutoStartAlert_Click"/>
                            <ui:ToggleSwitch x:Name="MahAppSwitch_AutoRestartAlert" Content="{loc:Tr MW.Alert.AutoRestart}" Margin="0,7" Click="Switch_AutoRestartAlert_Click"/>
                            <ui:ToggleSwitch x:Name="MahAppSwitch_AutoUpdateAlert" Content="{loc:Tr MW.Alert.AutoUpdate}" Margin="0,7" Click="Switch_AutoUpdateAlert_Click"/>
                            <ui:ToggleSwitch x:Name="MahAppSwitch_RestartCrontabAlert" Content="{loc:Tr MW.Alert.RestartCrontab}" Margin="0,7" Click="Switch_RestartCrontabAlert_Click"/>
                            <ui:ToggleSwitch x:Name="MahAppSwitch_CrashAlert" Content="{loc:Tr MW.Alert.Crash}" Margin="0,7" Click="Switch_CrashAlert_Click"/>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>
            </Grid>
            <Grid x:Name="MahAppFlyout_RestoreBackup" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="560" MaxHeight="600" CornerRadius="8" Padding="20" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <DockPanel MinWidth="360">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="3" Height="18" CornerRadius="2" Background="#4CC2D6" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <ui:SymbolIcon Symbol="History24" FontSize="18" Foreground="#4CC2D6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{loc:Tr MW.Restore.Title}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ui:Button DockPanel.Dock="Bottom" x:Name="button_RestoreBackup" Content="{loc:Tr MW.Common.Restore}" Click="Button_RestoreBackup_Click" Appearance="Primary" HorizontalAlignment="Right" MinWidth="120" Padding="14,4" Margin="0,16,0,0"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Label Content="{loc:Tr MW.Restore.ServerLabel}" Padding="0,0,6,0" VerticalAlignment="Center"/>
                            <Label x:Name="label_RestoreBackupServerName" Content="Server Name" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Label Content="{loc:Tr MW.Restore.SelectBackup}" Padding="0,0,0,4"/>
                        <ListBox x:Name="listbox_RestoreBackup" BorderThickness="1" MinWidth="320" MinHeight="200"/>
                    </StackPanel>
                </DockPanel>
            </Border>
            </Grid>
            <Grid x:Name="MahAppFlyout_SetAffinity" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="560" MaxHeight="600" CornerRadius="8" Padding="20" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <DockPanel MinWidth="380">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="3" Height="18" CornerRadius="2" Background="#4CC2D6" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="18" Foreground="#4CC2D6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{loc:Tr MW.Affinity.Title}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Tr MW.Affinity.Hint}" TextWrapping="Wrap" Opacity="0.7" Margin="13,0,0,14"/>
                    <Button DockPanel.Dock="Bottom" Content="{loc:Tr MW.Common.Close}" Click="SetAffinity_Close_Click" HorizontalAlignment="Right" MinWidth="90" Padding="14,4" Margin="0,14,0,0"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="360">
                        <Border CornerRadius="6" Padding="12,8" Background="{ui:ThemeResource ControlFillColorSecondaryBrush}">
                            <WrapPanel x:Name="StackPanel_SetAffinity" Orientation="Horizontal"/>
                        </Border>
                    </ScrollViewer>
                </DockPanel>
            </Border>
            </Grid>
