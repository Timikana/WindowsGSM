                            </DockPanel>
                        </DockPanel>
                        <TextBox x:Name="textbox_InstallLog" Margin="0,0,0,20" DockPanel.Dock="Top" TextWrapping="Wrap" IsReadOnly="true"/>
                    </DockPanel>
                </DockPanel>
            </Border>
            </Grid>
            <Grid x:Name="MahAppFlyout_ImportGameServer" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
