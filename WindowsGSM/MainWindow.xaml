<ui:FluentWindow x:Class="WindowsGSM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsGSM"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:ctrl="clr-namespace:WindowsGSM.Controls"
        mc:Ignorable="d"
        Title="WindowsGSM 2.0"
        Height="650"
        Width="1000" 
        Icon="Images\WindowsGSM-Icon-Border.ico"
        ResizeMode="CanResizeWithGrip"
        MinHeight="600"
        MinWidth="960"
        Closing="Window_Closing"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen" Activated="Window_Activated">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="WindowsGSM 2.0">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <ui:Button x:Name="button_Website" Content="Website" Icon="{ui:SymbolIcon Globe24}" Click="Button_Website_Click" Appearance="Transparent" Padding="8,2" Margin="2,0"/>
                    <ui:Button x:Name="button_Discord" Click="Button_Discord_Click" Appearance="Transparent" Padding="8,2" Margin="2,0">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Fill="#5865F2" Data="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/>
                            </Viewbox>
                            <TextBlock Text="Discord" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="button_Patreon" Click="Button_Patreon_Click" Appearance="Transparent" Padding="8,2" Margin="2,0">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Fill="#F96854" Data="M22.957 7.21c-.004-3.064-2.391-5.576-5.191-6.482-3.478-1.125-8.064-.962-11.384.604C2.357 3.231 1.093 7.391 1.046 11.54c-.039 3.411.302 12.396 5.369 12.46 3.765.047 4.326-4.804 6.068-7.141 1.24-1.662 2.836-2.132 4.801-2.618 3.376-.836 5.678-3.501 5.673-7.031Z"/>
                            </Viewbox>
                            <TextBlock Text="Patreon" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="button_Hide" Content="Hide" Icon="{ui:SymbolIcon EyeOff24}" Click="Button_Hide_Click" Appearance="Transparent" Padding="8,2" Margin="2,0"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>
        <!-- Container for the 9 dialog overlays: high ZIndex to cover the ENTIRE body (sibling Row 1) -->
        <Grid Grid.Row="1" Panel.ZIndex="100">
            <!-- Wizard: create a Discord bot token -->
            <Grid x:Name="MahAppFlyout_TokenHelp" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
                <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="580" CornerRadius="8" Padding="22" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Create a Discord bot token" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,14"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,7" Text="1.  Open the Discord Developer Portal and sign in."/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,7" Text="2.  &quot;New Application&quot; → give it a name → Create."/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,7" Text="3.  &quot;Bot&quot; tab → &quot;Reset Token&quot; → copy the token (shown only once)."/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,7" Text="4.  Still in &quot;Bot&quot; → enable &quot;MESSAGE CONTENT INTENT&quot; (required to read commands)."/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,7" Text="5.  Paste the token into WindowsGSM (Edit → paste → Save), then enable the bot."/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" Text="6.  Click &quot;Invite&quot; to add the bot to your server, then put your Discord ID in the Admin List."/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#E0A030" Margin="0,0,0,16" Text="⚠ Keep your token secret. If it leaks, use &quot;Reset Token&quot; in the portal."/>
                        <DockPanel>
                            <ui:Button Content="Open the Discord Portal" Icon="{ui:SymbolIcon Globe24}" Appearance="Primary" Click="TokenHelp_OpenPortal_Click"/>
                            <ui:Button Content="Close" DockPanel.Dock="Right" HorizontalAlignment="Right" Click="TokenHelp_Close_Click"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Grid>
            <!-- Manage a Discord admin: ID (+ name verification) and per-server permissions via checkboxes -->
            <Grid x:Name="MahAppFlyout_DiscordAdmin" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
                <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500" CornerRadius="8" Padding="20" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock x:Name="da_title" Text="Add a Discord admin" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14"/>
                        <TextBlock Text="User's Discord ID" Margin="0,0,0,4"/>
                        <DockPanel Margin="0,0,0,4">
                            <ui:Button Content="Verify" DockPanel.Dock="Right" Margin="8,0,0,0" Click="DiscordAdmin_Resolve_Click"/>
                            <TextBox x:Name="da_id" Padding="8,2" VerticalContentAlignment="Center" FontFamily="Consolas"/>
                        </DockPanel>
                        <TextBlock x:Name="da_resolved" Text="" FontSize="12" Foreground="Gray" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="Gray" Margin="0,0,0,12"
                                   Text="Tip: Discord → Settings → Advanced → Developer Mode. Then right-click the user → &quot;Copy ID&quot;."/>
                        <CheckBox x:Name="da_all" Content="All servers (full access)" Margin="0,0,0,8" Click="DiscordAdmin_AllToggled"/>
                        <TextBlock Text="Otherwise, choose the allowed servers:" FontSize="12" Margin="0,0,0,4"/>
                        <Border BorderBrush="{ui:ThemeResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,14">
                            <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="da_serverChecks">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Display}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="0,2"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                        <DockPanel>
                            <ui:Button Content="Save" Icon="{ui:SymbolIcon Save24}" Appearance="Primary" Click="DiscordAdmin_Save_Click"/>
                            <ui:Button Content="Cancel" DockPanel.Dock="Right" HorizontalAlignment="Right" Click="DiscordAdmin_Cancel_Click"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Grid>
            <!-- #21: wizard to build the cron schedule (restart) -->
            <Grid x:Name="MahAppFlyout_CrontabWizard" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
                <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="430" CornerRadius="8" Padding="18" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Wizard — restart schedule" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14"/>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="Frequency" Width="90" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cw_freq" SelectionChanged="CrontabWizard_Changed">
                                <ComboBoxItem Content="Every day" IsSelected="True"/>
                                <ComboBoxItem Content="Every week"/>
                            </ComboBox>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="Day" Width="90" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cw_day" SelectionChanged="CrontabWizard_Changed">
                                <ComboBoxItem Content="Monday" IsSelected="True"/>
                                <ComboBoxItem Content="Tuesday"/>
                                <ComboBoxItem Content="Wednesday"/>
                                <ComboBoxItem Content="Thursday"/>
                                <ComboBoxItem Content="Friday"/>
                                <ComboBoxItem Content="Saturday"/>
                                <ComboBoxItem Content="Sunday"/>
                            </ComboBox>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="Time" Width="90" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cw_minute" Width="70" DockPanel.Dock="Right" SelectionChanged="CrontabWizard_Changed"/>
                            <TextBlock Text="h" Width="18" DockPanel.Dock="Right" VerticalAlignment="Center" TextAlignment="Center"/>
                            <ComboBox x:Name="cw_hour" Width="70" HorizontalAlignment="Left" SelectionChanged="CrontabWizard_Changed"/>
                        </DockPanel>
                        <Border CornerRadius="4" Padding="8,6" Margin="0,4,0,12" Background="{ui:ThemeResource ControlFillColorSecondaryBrush}">
                            <TextBlock x:Name="cw_preview" FontFamily="Consolas" Text="cron: 0 6 * * *"/>
                        </Border>
                        <DockPanel>
                            <Button Content="Cancel" Click="CrontabWizard_Cancel" Width="90" DockPanel.Dock="Left"/>
                            <Button Content="Apply" Click="CrontabWizard_Apply" Width="110" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Grid>
            <Grid x:Name="MahAppFlyout_ViewPlugins" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="640" MaxHeight="660" CornerRadius="8" Padding="8" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Vertical">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                            <Label Content="Installed:" Margin="12,0,0,10" FontSize="14" FontWeight="SemiBold" Padding="5,5.5,0,5"></Label>
                            <Label x:Name="Label_PluginInstalled" Content=" 0" Margin="0,0,10,10" FontSize="15" FontWeight="SemiBold" Foreground="Aqua"></Label>
                            <Label Content="Loaded:" Margin="0,0,0,10" FontSize="14" FontWeight="SemiBold" Padding="5,5.5,0,5"></Label>
                            <Label x:Name="Label_PluginLoaded" Content="0" Margin="0,0,10,10" FontSize="15" FontWeight="SemiBold" Foreground="GreenYellow"></Label>
                            <Label Content="Failed:" Margin="0,0,0,10" FontSize="14" FontWeight="SemiBold" Padding="5,5.5,0,5"></Label>
                            <Label x:Name="Label_PluginFailed" Content="0" Margin="0,0,10,10" FontSize="15" FontWeight="SemiBold" Foreground="Red"></Label>
                        </StackPanel>
                        <Button x:Name="Button_ImportPlugin" Content="Import Plugin" Height="29" Width="130" HorizontalAlignment="Right" Click="ImportPlugin_Click" Margin="-20,-50,150,0"></Button>
                        <Button x:Name="Button_RefreshPlugins" Content="Reload Plugins" Height="29" Width="130" HorizontalAlignment="Right" Margin="-20,-50,12,0" Click="RefreshPlugins_Click"></Button>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                        <Label Content="✔️" Margin="10,0,0,10" FontSize="17" FontWeight="SemiBold" Foreground="GreenYellow"></Label>
                        <Label Content="Loaded Plugin List" Margin="0,0,10,10" FontSize="17" FontWeight="SemiBold"></Label>
                    </StackPanel>

                    <ProgressBar x:Name="ProgressRing_LoadPlugins" IsIndeterminate="True" Foreground="{DynamicResource AccentFillColorDefaultBrush}" Margin="10,0,10,10" DockPanel.Dock="Top" Visibility="Collapsed"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="StackPanel_PluginList">
                            <!--
                            <Border BorderBrush="GreenYellow" Background="SlateGray" BorderThickness="1.5" CornerRadius="5" Padding="6" Margin="10,0,10,10">
                                <DockPanel>
                                    <Border BorderBrush="White" BorderThickness="0" CornerRadius="5" Padding="10" Width="61" Height="61" Margin="0,0,10,0">
                                        <Border.Background><ImageBrush Stretch="Fill" ImageSource="Images/Games/arma3.png"></ImageBrush></Border.Background>
                                    </Border>

                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,3,0">
                                        <Label Content="v1.0" DockPanel.Dock="Right" Padding="0"></Label>
                                        <Label Content="WindowsGSM.ARMA3" DockPanel.Dock="Left" FontSize="14" FontWeight="Bold" Padding="0"></Label>
                                    </DockPanel>

                                    <TextBlock Text="WindowsGSM Plugin - Arma 3 Dedicated Server" DockPanel.Dock="Top"></TextBlock>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Border BorderBrush="DimGray" BorderThickness="0" CornerRadius="30" Padding="10" Width="25" Height="25" Margin="0,0,5,0">
                                            <Border.Background><ImageBrush Stretch="Fill" ImageSource="Images/Games/tf2.png"></ImageBrush></Border.Background>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Label Content="BattlefieldDuck" DockPanel.Dock="Top" Padding="0" ></Label>
                                            <Label Content="•" DockPanel.Dock="Top" Padding="0" Margin="5,0,5,0" ></Label>
                                            <TextBlock><Hyperlink Foreground="GreenYellow">https://github.com/BattlefieldDuck</Hyperlink></TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            -->

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
            </Grid>
            <Grid x:Name="MahAppFlyout_Settings" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="640" MaxHeight="660" CornerRadius="8" Padding="8" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_HardWareAcceleration" Content="Hardware Acceleration" Margin="20,10,0,15" Click="HardWareAcceleration_IsCheckedChanged"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_UIAnimation" Content="UI Animation" Margin="20,0,0,15" Click="UIAnimation_IsCheckedChanged"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_DarkTheme" Content="Dark Theme" Margin="20,0,0,15" Click="DarkTheme_IsCheckedChanged"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_StartOnBoot" Content="Start WindowsGSM on Login" Margin="20,0,0,15" Click="StartOnLogin_IsCheckedChanged"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_RestartOnCrash" Content="Auto Restart WindowsGSM on Crash" Margin="20,0,0,15" Click="RestartOnCrash_IsCheckedChanged"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_SendStatistics" Content="Send Statistics" Margin="20,0,0,15" Click="SendStatistics_IsCheckedChanged"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_DonorConnect" Content="Donor Connect (Patreon)" Margin="20,0,0,15" Click="DonorConnect_IsCheckedChanged"/>
                        <DockPanel Margin="20,0,20,20">
                            <Label Content="WindowsGSM Theme (Donor Only)" FontSize="13.5" Padding="0" DockPanel.Dock="Top"></Label>
                            <ComboBox x:Name="comboBox_Themes" Margin="0,5,0,0" Height="25" DockPanel.Dock="Top" SelectionChanged="ComboBox_Themes_SelectionChanged" IsEnabled="False"></ComboBox>
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            </Grid>
            <Grid x:Name="MahAppFlyout_DiscordAlert" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="640" MaxHeight="660" CornerRadius="8" Padding="8" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Orientation="Horizontal">
                        <ui:ToggleSwitch x:Name="MahAppSwitch_AutoStartAlert" Content="Auto Start Alert" Margin="20,20,0,20" Click="Switch_AutoStartAlert_Click"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_AutoRestartAlert" Content="Auto Restart Alert" Margin="0,20,0,20" Click="Switch_AutoRestartAlert_Click"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_AutoUpdateAlert" Content="Auto Update Alert" Margin="0,20,0,20" Click="Switch_AutoUpdateAlert_Click"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_RestartCrontabAlert" Content="Restart Crontab Alert" Margin="0,20,0,20" Click="Switch_RestartCrontabAlert_Click"/>
                        <ui:ToggleSwitch x:Name="MahAppSwitch_CrashAlert" Content="Crash Alert" Margin="20,20,0,20" Click="Switch_CrashAlert_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            </Grid>
            <Grid x:Name="MahAppFlyout_RestoreBackup" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="640" MaxHeight="660" CornerRadius="8" Padding="8" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <Grid Margin="15,0,15,15">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,35">
                        <DockPanel DockPanel.Dock="Top">
                            <Label DockPanel.Dock="Left" Content="Server:" Padding="5,5,0,5"/>
                            <Label x:Name="label_RestoreBackupServerName" Content="Server Name"/>
                        </DockPanel>
                        <Label DockPanel.Dock="Top" Content="Please select a backup"/>
                        <ListBox x:Name="listbox_RestoreBackup" DockPanel.Dock="Top" BorderThickness="1" Width="300"/>
                    </DockPanel>
                    <Button VerticalAlignment="Bottom" x:Name="button_RestoreBackup" Content="Restore" Click="Button_RestoreBackup_Click"/>
                </Grid>
            </Border>
            </Grid>
            <Grid x:Name="MahAppFlyout_SetAffinity" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="640" MaxHeight="660" CornerRadius="8" Padding="8" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="StackPanel_SetAffinity" Orientation="Horizontal" VerticalAlignment="Center" Margin="20"/>
                </ScrollViewer>
            </Border>
            </Grid>
            <Grid x:Name="MahAppFlyout_EditConfig" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="640" MaxHeight="660" CornerRadius="8" Padding="8" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <Grid Margin="15,0,15,15">
                    <DockPanel Margin="0,0,0,35">
                        <StackPanel DockPanel.Dock="Top">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <StackPanel>
                                    <Label Content="Server ID"></Label>
                                    <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textbox_EC_ServerID" Height="28" Width="120" TextWrapping="Wrap" Text="" FontFamily="Consolas" VerticalAlignment="Top" IsReadOnly="True"/>
                                </StackPanel>
                                <StackPanel Margin="5,0,0,0">
                                    <Label Content="Server Game"></Label>
                                    <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textbox_EC_ServerGame" Height="28" Width="375" TextWrapping="Wrap" Text="" FontFamily="Consolas" VerticalAlignment="Top" IsReadOnly="True"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <Label Content="Server Name"></Label>
                                <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textbox_EC_ServerName" Height="28" Width="500" TextWrapping="Wrap" Text="" FontFamily="Consolas" VerticalAlignment="Top"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <StackPanel>
                                    <Label Content="Server IP Address"></Label>
                                    <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textbox_EC_ServerIP" Height="28" Width="120" TextWrapping="Wrap" Text="" FontFamily="Consolas" VerticalAlignment="Top"/>
                                </StackPanel>
                                <StackPanel Margin="5,0,0,0">
                                    <Label Content="Server Port"></Label>
                                    <ui:NumberBox x:Name="numericUpDown_EC_ServerPort" Minimum="1" Maximum="65535" FontFamily="Consolas" Width="150"/>
                                </StackPanel>
                                <StackPanel Margin="5,0,0,0">
                                    <Label Content="Server Query Port"></Label>
                                    <ui:NumberBox x:Name="numericUpDown_EC_ServerQueryPort" Minimum="1" Maximum="65535" FontFamily="Consolas" Width="150"/>
                                </StackPanel>
                                <StackPanel Margin="5,0,0,0">
                                    <Label Content="Server Maxplayer"></Label>
                                    <ui:NumberBox x:Name="numericUpDown_EC_ServerMaxplayer" Minimum="1" Maximum="100000" FontFamily="Consolas" Width="150"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <Label Content="Server Start Map"></Label>
                                <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textbox_EC_ServerMap" Height="28" Width="500" FontFamily="Consolas" TextWrapping="Wrap" Text="" VerticalAlignment="Top"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <Label Content="Server GSLT"></Label>
                                <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textbox_EC_ServerGSLT" Height="28" Width="500" FontFamily="Consolas" TextWrapping="Wrap" Text="" VerticalAlignment="Top"/>
                            </StackPanel>
                            <StackPanel>
                                <Label Content="Server Start Param"></Label>
                            </StackPanel>
                        </StackPanel>
                        <TextBox x:Name="textbox_EC_ServerParam" Width="500" TextWrapping="Wrap" FontFamily="Consolas" Text="" DockPanel.Dock="Top"/>
                    </DockPanel>
                    <Button x:Name="button_EC_SaveConfig" VerticalAlignment="Bottom" Content="Save" Width="500" Height="25" Click="Button_EditConfig_Save_Click"/>
                </Grid>
            </Border>
            </Grid>
            <Grid x:Name="MahAppFlyout_ManageAddons" Panel.ZIndex="100" MouseLeftButtonDown="Overlay_BackdropClick" Visibility="Collapsed" Background="#F2000000">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="640" MaxHeight="660" CornerRadius="8" Padding="8" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <DockPanel VerticalAlignment="Stretch" Height="Auto">
