                        </DockPanel>

                    </DockPanel>
                </DockPanel>
            </Border>
            </Grid>
        <!-- (flyouts converted to overlay panels above) -->

    <Grid Grid.Row="1">
        <DockPanel Name="hMenu_Discordbot" Margin="190,0,0,0" Visibility="Visible">
            <Grid DockPanel.Dock="Top">
                <DockPanel Margin="10,10,10,10" DockPanel.Dock="Top">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Left">
                            <DockPanel DockPanel.Dock="Top">
                                <DockPanel DockPanel.Dock="Top">
                                    <Label DockPanel.Dock="Top" Content="DISCORD BOT" FontWeight="SemiBold" Foreground="Gray"/>
                                </DockPanel>
                                <DockPanel DockPanel.Dock="Top">
                                    <Label Content="Usage: Remote control the game servers with Discord" DockPanel.Dock="Left"/>
                                    <Button x:Name="button_DiscordBotInvite" DockPanel.Dock="Right" HorizontalAlignment="Right" Content="Invite" Width="75" Height="23" Click="Button_DiscordBotInvite_Click" IsEnabled="False"/>
                                </DockPanel>
                                <Label Content="Available commands:" DockPanel.Dock="Top"/>
                                <Label x:Name="label_DiscordBotCommands" Content="" FontFamily="Consolas" DockPanel.Dock="Top"/>
                            </DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="5,10,0,0">
                                <ui:ToggleSwitch DockPanel.Dock="Left" VerticalAlignment="Center" x:Name="switch_DiscordBot" Content="Enable" Width="140" Click="Switch_DiscordBot_Toggled"/>
                                <ui:ToggleSwitch DockPanel.Dock="Left" VerticalAlignment="Center" x:Name="MahAppSwitch_DiscordBotAutoStart" Content="Auto Start" Width="140" Click="Switch_DiscordBotAutoStart_Click"/>
                                <DockPanel DockPanel.Dock="Top" Margin="10,0,0,0">
                                    <DockPanel DockPanel.Dock="Top">
                                        <Label DockPanel.Dock="Left" Content="Bot Prefix"/>
                                        <Button DockPanel.Dock="Right" x:Name="button_DiscordBotPrefixEdit" Content="Edit" Margin="0,0,0,5" HorizontalAlignment="Right" Width="75" Height="23" Click="Button_DiscordBotPrefixEdit_Click"/>
                                    </DockPanel>
                                    <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textBox_DiscordBotPrefix" Height="24" DockPanel.Dock="Top" Text="" Margin="0,0,0,0" Width="170" IsEnabled="False" FontFamily="Consolas"/>
                                </DockPanel>
                            </DockPanel>

                            <DockPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                                <Label Content="Discord Bot Token"/>
                                <Button x:Name="button_DiscordBotTokenEdit" DockPanel.Dock="Right" Content="Edit" Margin="0,0,0,5" HorizontalAlignment="Right" Width="75" Height="23" Click="Button_DiscordBotTokenEdit_Click"/>
                                <ui:Button DockPanel.Dock="Right" Content="How to get a token?" Icon="{ui:SymbolIcon QuestionCircle24}" Margin="0,0,8,5" Padding="8,2" Height="23" Click="TokenHelp_Open_Click"/>
                            </DockPanel>
                            <Grid DockPanel.Dock="Top">
                                <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textBox_DiscordBotToken" Height="24" Text="" IsEnabled="False" FontFamily="Consolas"/>
                                <Rectangle x:Name="rectangle_DiscordBotTokenSpoiler" Fill="#FF2B2B2B" Height="20" Stroke="Black" VerticalAlignment="Top" Margin="3"/>
                            </Grid>

                            <!-- Live dashboard message: posts/updates a status message in a channel -->
                            <DockPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                                <DockPanel DockPanel.Dock="Left" Width="280">
                                    <DockPanel DockPanel.Dock="Top">
                                        <Label Content="Dashboard Channel ID(s)" ToolTip="One or more channels (one per Discord server), separated by commas"/>
                                        <Button x:Name="button_DiscordBotDashboardEdit" DockPanel.Dock="Right" Content="Edit" Margin="35,0,0,5" HorizontalAlignment="Right" Width="75" Height="23" Click="Button_DiscordBotDashboardEdit_Click"/>
                                    </DockPanel>
                                    <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textBox_DiscordBotDashboard" Height="24" DockPanel.Dock="Top" Text="" IsEnabled="False" FontFamily="Consolas"/>
                                </DockPanel>
                                <DockPanel DockPanel.Dock="Right" Margin="10,0,0,0">
                                    <Label Content="Refresh (sec)" DockPanel.Dock="Top"/>
                                    <ui:NumberBox x:Name="numericUpDown_DiscordRefreshRate" Minimum="10" Maximum="900" Margin="0,4,0,0"/>
                                </DockPanel>
                            </DockPanel>

                            <!-- Admin panel: persistent embed + dropdown menu + action buttons, in a dedicated channel -->
                            <DockPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                                <DockPanel DockPanel.Dock="Top">
                                    <Label Content="Admin Panel Channel ID(s)" ToolTip="Channel dedicated to administration (one per Discord server), separated by commas. The bot maintains an interactive panel there (dropdown menu + buttons)."/>
                                    <Button x:Name="button_DiscordBotAdminPanelEdit" DockPanel.Dock="Right" Content="Edit" Margin="35,0,0,5" HorizontalAlignment="Right" Width="75" Height="23" Click="Button_DiscordBotAdminPanelEdit_Click"/>
                                </DockPanel>
                                <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textBox_DiscordBotAdminPanel" Height="24" DockPanel.Dock="Top" Text="" IsEnabled="False" FontFamily="Consolas"/>
                            </DockPanel>

                            <DockPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                                <Label Content="Discord Bot Log"/>
                            </DockPanel>
                            <TextBox x:Name="textBox_DiscordBotLog" FontFamily="Consolas" MaxWidth="465" DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" TextWrapping="NoWrap"/>
                        </DockPanel>
                        <DockPanel DockPanel.Dock="Right" Margin="20,0,0,0">
                            <DockPanel DockPanel.Dock="Top">
                                <Label Content="Admin List"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="button_DiscordBotAddID" Content="Add Admin ID" Margin="0,0,5,5" HorizontalAlignment="Right" Width="97" Height="23" Click="Button_DiscordBotAddID_Click"/>
                                    <Button x:Name="button_DiscordBotEditServerID" Content="Edit Server ID" Margin="0,0,5,5" HorizontalAlignment="Right" Width="97" Height="23" Click="Button_DiscordBotEditServerID_Click"/>
                                    <Button x:Name="button_DiscordBotRemoveID" Content="Remove" Margin="0,0,0,5" HorizontalAlignment="Right" Width="70" Height="23" Click="Button_DiscordBotRemoveID_Click"/>
                                </StackPanel>
                            </DockPanel>
                            <DataGrid x:Name="listBox_DiscordBotAdminList" SelectionMode="Single" BorderThickness="1" DockPanel.Dock="Top">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Admin ID" IsReadOnly="True" Binding="{Binding Path=AdminId}" Width="150" MinWidth="150" MaxWidth="150" FontFamily="Consolas"/>
                                    <DataGridTextColumn Header="User" IsReadOnly="True" Binding="{Binding Path=Username}" Width="150" MinWidth="120"/>
                                    <DataGridTextColumn Header="Server IDs" IsReadOnly="True" Binding="{Binding Path=ServerIds}" Width="1*" FontFamily="Consolas"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </DockPanel>
                </DockPanel>
            </Grid>
        </DockPanel>

        <DockPanel Name="hMenu_Dashboard" Margin="190,0,0,0" Visibility="Hidden">
            <Grid Margin="10,10,10,10">
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <DockPanel>
                    <Border DockPanel.Dock="Top" CornerRadius="6" Padding="14,10" Margin="0,0,0,12" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                        <DockPanel>
                            <TextBlock Text="Server status" FontWeight="SemiBold" FontSize="14" DockPanel.Dock="Top" Margin="0,0,0,6"/>
                            <TextBlock x:Name="dashboard_health" FontSize="14" TextWrapping="Wrap" Text="—"/>
                        </DockPanel>
                    </Border>

                    <!-- Per-server tiles: status + live CPU/RAM + mini-charts + players -->
                    <Label DockPanel.Dock="Top" Content="SERVERS" FontWeight="SemiBold" Foreground="Gray"/>
                    <ItemsControl DockPanel.Dock="Top" x:Name="dashboard_tiles" Margin="0,4,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="246" Margin="0,0,8,8" CornerRadius="6" Padding="12,10"
                                        Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                                    <StackPanel>
                                        <DockPanel LastChildFill="True" Margin="0,0,0,4">
                                            <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,6,0" DockPanel.Dock="Left">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="Gray"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Online}" Value="True">
                                                                <Setter Property="Fill" Value="#2ECC71"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="6,0,0,0" DockPanel.Dock="Right"
                                                     Fill="#F1C40F" ToolTip="{Binding UpdateTooltip}"
                                                     Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding Game}" FontSize="11" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <DockPanel>
                                                    <TextBlock Text="CPU" FontSize="11" Foreground="Gray" DockPanel.Dock="Left"/>
                                                    <TextBlock Text="{Binding Cpu}" FontSize="11" HorizontalAlignment="Right"/>
                                                </DockPanel>
                                                <ctrl:Sparkline Height="26" Max="100" Stroke="RoyalBlue" Values="{Binding CpuHistory}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <DockPanel>
                                                    <TextBlock Text="RAM" FontSize="11" Foreground="Gray" DockPanel.Dock="Left"/>
                                                    <TextBlock Text="{Binding Ram}" FontSize="11" HorizontalAlignment="Right"/>
                                                </DockPanel>
                                                <ctrl:Sparkline Height="26" Stroke="MediumPurple" Values="{Binding RamHistory}"/>
                                            </StackPanel>
                                        </Grid>
                                        <DockPanel Margin="0,6,0,0">
                                            <TextBlock Text="Players" FontSize="11" Foreground="Gray" DockPanel.Dock="Left"/>
                                            <TextBlock Text="{Binding Players}" FontSize="11" HorizontalAlignment="Right"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Label DockPanel.Dock="Top" Content="SYSTEM METRICS" FontWeight="SemiBold" Foreground="Gray"/>
                    <DockPanel DockPanel.Dock="Top">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="10px"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="10px"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <DockPanel Grid.Column="0" Background="{DynamicResource ApplicationBackgroundBrush}">
                                <Grid DockPanel.Dock="Left" Background="RoyalBlue" Height="Auto" Width="5"/>
                                <DockPanel Margin="15">
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                        <Label DockPanel.Dock="Left" Content="CPU" FontSize="25" Padding="0"/>
                                        <Label DockPanel.Dock="Right" Content="" VerticalAlignment="Bottom" HorizontalAlignment="Right" x:Name="dashboard_cpu_type"/>
                                    </DockPanel>
                                    <DockPanel DockPanel.Dock="Top">
                                        <Label DockPanel.Dock="Left" Content="0%" Padding="0" x:Name="dashboard_cpu_usage"/>
                                        <Label DockPanel.Dock="Left" Content="" Padding="0"/>
                                    </DockPanel>
                                    <ProgressBar DockPanel.Dock="Left" Height="20" Value="30" Background="{DynamicResource ControlFillColorDefaultBrush}" Foreground="RoyalBlue" x:Name="dashboard_cpu_bar"/>
                                </DockPanel>
                            </DockPanel>
                            <DockPanel Grid.Column="2" Background="{DynamicResource ApplicationBackgroundBrush}">
                                <Grid DockPanel.Dock="Left" Background="Purple" Height="Auto" Width="5"/>
                                <DockPanel Margin="15">
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                        <Label DockPanel.Dock="Left" Content="Memory" FontSize="25" Padding="0"/>
                                        <Label DockPanel.Dock="Right" Content="" VerticalAlignment="Bottom" HorizontalAlignment="Right" x:Name="dashboard_ram_type"/>
                                    </DockPanel>
                                    <DockPanel DockPanel.Dock="Top">
                                        <Label DockPanel.Dock="Left" Content="0%" Padding="0" x:Name="dashboard_ram_usage"/>
                                        <Label DockPanel.Dock="Right" Content="/" Padding="0" HorizontalAlignment="Right" x:Name="dashboard_ram_ratio"/>
                                    </DockPanel>
                                    <ProgressBar DockPanel.Dock="Left" Height="20" Value="50" Background="{DynamicResource ControlFillColorDefaultBrush}" Foreground="Purple" x:Name="dashboard_ram_bar"/>
                                </DockPanel>
                            </DockPanel>
                            <DockPanel Grid.Column="4" Background="{DynamicResource ApplicationBackgroundBrush}">
                                <Grid DockPanel.Dock="Left" Background="ForestGreen" Height="Auto" Width="5"/>
                                <DockPanel Margin="15">
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                        <Label DockPanel.Dock="Left" Content="Disk" FontSize="25" Padding="0"/>
                                        <Label DockPanel.Dock="Left" Content="" FontSize="25" Padding="5,0,0,0" x:Name="dashboard_disk_name"/>
                                        <Label DockPanel.Dock="Right" Content="" VerticalAlignment="Bottom" HorizontalAlignment="Right" x:Name="dashboard_disk_type"/>
                                    </DockPanel>
                                    <DockPanel DockPanel.Dock="Top">
                                        <Label DockPanel.Dock="Left" Content="0%" Padding="0" x:Name="dashboard_disk_usage"/>
                                        <Label DockPanel.Dock="Right" Content="/" Padding="0" HorizontalAlignment="Right" x:Name="dashboard_disk_ratio"/>
                                    </DockPanel>
                                    <ProgressBar DockPanel.Dock="Left" Height="20" Value="50" Background="{DynamicResource ControlFillColorDefaultBrush}" Foreground="ForestGreen" x:Name="dashboard_disk_bar"/>
                                </DockPanel>
                            </DockPanel>
                        </Grid>
                    </DockPanel>

                    <Label DockPanel.Dock="Top" Content="GAME SERVERS" FontWeight="SemiBold" Foreground="Gray" Margin="0,10,0,0"/>
                    <DockPanel DockPanel.Dock="Top" x:Name="dashboard_gameservers">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="10px"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="10px"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <DockPanel Grid.Column="0" Background="{DynamicResource ApplicationBackgroundBrush}">
                                <Grid DockPanel.Dock="Left" Background="MediumVioletRed" Height="Auto" Width="5"/>
                                <DockPanel Margin="15">
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                        <Label DockPanel.Dock="Left" Content="Servers" FontSize="25" Padding="0"/>
                                        <Label DockPanel.Dock="Right" Content="Installed server count" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                    </DockPanel>
                                    <DockPanel DockPanel.Dock="Top">
                                        <Label DockPanel.Dock="Left" Content="0%" Padding="0" x:Name="dashboard_servers_usage"/>
                                        <Label DockPanel.Dock="Right" Content="/" Padding="0" HorizontalAlignment="Right" x:Name="dashboard_servers_ratio"/>
                                    </DockPanel>
                                    <ProgressBar DockPanel.Dock="Left" Height="20" Value="30" Background="{DynamicResource ControlFillColorDefaultBrush}" Foreground="MediumVioletRed" x:Name="dashboard_servers_bar"/>
                                </DockPanel>
                            </DockPanel>
                            <DockPanel Grid.Column="2" Background="{DynamicResource ApplicationBackgroundBrush}">
                                <Grid DockPanel.Dock="Left" Background="SpringGreen" Height="Auto" Width="5"/>
                                <DockPanel Margin="15">
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                        <Label DockPanel.Dock="Left" Content="Online" FontSize="25" Padding="0"/>
                                        <Label DockPanel.Dock="Right" Content="Started server count" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                    </DockPanel>
                                    <DockPanel DockPanel.Dock="Top">
                                        <Label DockPanel.Dock="Left" Content="0%" Padding="0" x:Name="dashboard_started_usage"/>
                                        <Label DockPanel.Dock="Right" Content="/" Padding="0" HorizontalAlignment="Right" x:Name="dashboard_started_ratio"/>
                                    </DockPanel>
                                    <ProgressBar DockPanel.Dock="Left" Height="20" Value="50" Background="{DynamicResource ControlFillColorDefaultBrush}" Foreground="SpringGreen" x:Name="dashboard_started_bar"/>
                                </DockPanel>
                            </DockPanel>
                            <DockPanel Grid.Column="4" Background="{DynamicResource ApplicationBackgroundBrush}">
                                <Grid DockPanel.Dock="Left" Background="Goldenrod" Height="Auto" Width="5"/>
                                <DockPanel Margin="15">
                                    <DockPanel DockPanel.Dock="Top">
                                        <Label DockPanel.Dock="Left" Content="Active Players" FontSize="25" VerticalAlignment="Center"/>
                                        <Label DockPanel.Dock="Right" Content="0" FontSize="25" HorizontalAlignment="Right" VerticalAlignment="Center" x:Name="dashboard_players_count"/>
                                    </DockPanel>
                                </DockPanel>
                            </DockPanel>
                        </Grid>
                    </DockPanel>

