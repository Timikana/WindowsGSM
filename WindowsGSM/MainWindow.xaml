                            TextChanged="TextBox_Search_TextChanged"/>
            </Grid>
            <Grid Height="1" Background="Black" DockPanel.Dock="Top"/>
            <Grid DockPanel.Dock="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="4*" MinHeight="210"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="ServerGrid"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          RowHeaderWidth="0"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          DockPanel.Dock="Top"
                          SelectionChanged="DataGrid_SelectionChanged"
                          IsSynchronizedWithCurrentItem="True"
                          HorizontalScrollBarVisibility="Disabled"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          CanUserSortColumns="True"
                          RowHeight="34"
                          ColumnHeaderHeight="38"
                          FontSize="13"
                          VerticalContentAlignment="Center"
                          AlternationCount="2">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" IsReadOnly="True" Binding="{Binding Path=ID}" Width="35" MinWidth="35" MaxWidth="35"/>
                        <DataGridTextColumn Header="PID" IsReadOnly="True" Binding="{Binding Path=PID}" Width="65" MinWidth="55" MaxWidth="95"/>
                        <DataGridTemplateColumn Header="MOD" IsReadOnly="True" Width="53" MinWidth="53" MaxWidth="53">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Icon}" Width="18"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{loc:Tr MW.Col.Status}" IsReadOnly="True" Binding="{Binding Path=StatusDisplay}" Width="80" MinWidth="80" MaxWidth="80"/>
                        <DataGridTemplateColumn Header="{loc:Tr MW.Col.Update}" IsReadOnly="True" Width="44" MinWidth="44" MaxWidth="44">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse Width="12" Height="12" Fill="Orange" HorizontalAlignment="Center" VerticalAlignment="Center"
                                             ToolTip="{Binding UpdateTooltip}"
                                             Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{loc:Tr MW.Col.ServerName}" IsReadOnly="True" Binding="{Binding Path=Name}" Width="10*" MinWidth="105"/>
                        <DataGridTextColumn Header="{loc:Tr MW.Col.IPAddress}" IsReadOnly="True" Binding="{Binding Path=IP}" Width="4*" MinWidth="88"/>
                        <DataGridTextColumn Header="{loc:Tr MW.Col.Port}" IsReadOnly="True" Binding="{Binding Path=Port}" Width="4*" MinWidth="52">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PortConflict}" Value="True">
                                            <Setter Property="Foreground" Value="OrangeRed"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="ToolTip" Value="{Binding PortConflictTooltip}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="{loc:Tr MW.Col.QueryPort}" IsReadOnly="True" Binding="{Binding Path=QueryPort}" Width="4*" MinWidth="93"/>
                        <DataGridTextColumn Header="{loc:Tr MW.Col.Map}" IsReadOnly="True" Binding="{Binding Path=Defaultmap}" Width="7*" MinWidth="50"/>
                        <DataGridTextColumn Header="{loc:Tr MW.Col.Players}" IsReadOnly="True" Binding="{Binding Path=Maxplayers}" Width="3*" MinWidth="70"/>
                        <DataGridTextColumn Header="{loc:Tr MW.Col.OnlinePlayers}" IsReadOnly="True" Binding="{Binding Path=Players}" Width="3*" MinWidth="70" ToolTipService.ToolTip="{loc:Tr MW.Col.OnlinePlayersTip}"/>
                        <DataGridTextColumn Header="{loc:Tr MW.Col.CPU}" IsReadOnly="True" Binding="{Binding Path=Cpu}" Width="3*" MinWidth="55"/>
                        <DataGridTextColumn Header="{loc:Tr MW.Col.RAM}" IsReadOnly="True" Binding="{Binding Path=Ram}" Width="3*" MinWidth="70"/>
                        <DataGridTextColumn Header="{loc:Tr MW.Col.Uptime}" IsReadOnly="True" Binding="{Binding Path=Uptime}" Width="4*" MinWidth="80"/>
                        <!--<DataGridTextColumn Header="RAM Usage" IsReadOnly="True" Binding="{Binding Path=RamUsage}" Width="4*"/>-->
                    </DataGrid.Columns>
                </DataGrid>
                <!-- Loading overlay: shown over the server grid while plugins compile in the background
                     (they are needed before plugin-backed servers can appear). Collapsed once ready. -->
                <StackPanel x:Name="LoadingOverlay_Servers" Grid.Row="0" Orientation="Vertical"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Panel.ZIndex="50" IsHitTestVisible="False" Visibility="Collapsed">
                    <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr MW.Home.Loading}" Margin="0,12,0,0" HorizontalAlignment="Center"
                               FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch">
                    <GridSplitter.Background>
                        <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlDarkDarkColorKey}}"/>
                    </GridSplitter.Background>
                </GridSplitter>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="475" MaxWidth="475"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel LastChildFill="True" Margin="6,6,6,6">
                        <!-- Clear log (bottom) -->
                        <Button x:Name="button_clearwgsmlog" DockPanel.Dock="Bottom" Cursor="Hand" Content="{loc:Tr MW.Common.Clear}" Margin="0,4,0,0" Height="24" MinWidth="60" Padding="10,0" Click="Button_ClearWGSMLog_Click" HorizontalAlignment="Left"/>

                        <!-- Per-server settings — flexible rows so translated labels never overlap/clip.
                             Wrapped in a height-bounded ScrollViewer so wrapped (translated) rows scroll
                             instead of pushing the Log window out of view. -->
                        <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="300">
                        <StackPanel>

                            <!-- Header row: server status badge (left) + edit config (right) -->
                            <Grid Margin="2,2,4,12">
                                <Button x:Name="button_Status" Content="" MinWidth="86" Height="28" Padding="12,0" FontSize="11" FontWeight="SemiBold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="Orange" Foreground="White" BorderThickness="0" IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <Button x:Name="button_EditConfig" Content="{loc:Tr MW.Panel.EditConfig}" Cursor="Hand" MinWidth="120" Padding="10,3" Height="28" Click="Button_EditConfig_Click" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- CARD: Performance & resources -->
                            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,8" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                                        <Border Width="3" Height="15" CornerRadius="2" Background="#4CC2D6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <ui:SymbolIcon Symbol="Options24" FontSize="15" Foreground="#4CC2D6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Tr MW.Panel.SecPerformance}" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,7">
                                        <Label x:Name="label_ProcessPriority" Content="{loc:Tr MW.Panel.ProcessPriority}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <Slider x:Name="slider_ProcessPriority" VerticalAlignment="Center" Width="90" Height="25" Minimum="0" Maximum="5" IsSnapToTickEnabled="True" TickPlacement="BottomRight" ValueChanged="Slider_ProcessPriority_ValueChanged" Margin="0,0,8,0"/>
                                        <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textBox_ProcessPriority" Height="26" TextWrapping="NoWrap" Text="" IsReadOnly="true" Width="90" FontFamily="Consolas" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,7">
                                        <Button x:Name="button_SetAffinity" Content="{loc:Tr MW.Panel.SetAffinity}" VerticalAlignment="Center" MinWidth="115" Padding="10,3" Height="28" Click="Button_SetAffinity_Click" Margin="0,0,8,0"/>
                                        <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textBox_SetAffinity" Height="26" TextWrapping="NoWrap" Text="" IsReadOnly="true" Width="70" FontFamily="Consolas" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Orientation="Horizontal">
                                        <ui:ToggleSwitch x:Name="switch_memwatchdog" Content="{loc:Tr MW.Panel.RamWatchdog}" VerticalAlignment="Center" Click="Button_MemWatchdog_Click" Margin="0,0,16,0"/>
                                        <Label Content="{loc:Tr MW.Panel.Limit}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBox x:Name="textBox_memlimit" Padding="8,2" VerticalContentAlignment="Center" Height="26" Width="70" VerticalAlignment="Center" FontFamily="Consolas" LostFocus="TextBox_MemLimit_LostFocus" Margin="0,0,6,0"/>
                                        <Label Content="MB" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- CARD: Automation -->
                            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,8" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                                        <Border Width="3" Height="15" CornerRadius="2" Background="#4CC2D6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <ui:SymbolIcon Symbol="ArrowSync24" FontSize="15" Foreground="#4CC2D6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Tr MW.Panel.SecAutomation}" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal">
                                        <ui:ToggleSwitch x:Name="switch_autostart" Content="{loc:Tr MW.Panel.AutoStart}" VerticalAlignment="Center" Click="Button_AutoStart_Click" Margin="0,0,22,6"/>
                                        <ui:ToggleSwitch x:Name="switch_autorestart" Content="{loc:Tr MW.Panel.AutoRestart}" VerticalAlignment="Center" Click="Button_AutoRestart_Click" Margin="0,0,22,6"/>
                                        <ui:ToggleSwitch x:Name="switch_autoupdate" Content="{loc:Tr MW.Panel.AutoUpdate}" VerticalAlignment="Center" Click="Button_AutoUpdate_Click" Margin="0,0,0,6"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- CARD: On startup -->
                            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,8" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                                        <Border Width="3" Height="15" CornerRadius="2" Background="#4CC2D6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <ui:SymbolIcon Symbol="Play24" FontSize="15" Foreground="#4CC2D6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Tr MW.Panel.SecStartup}" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal">
                                        <ui:ToggleSwitch x:Name="switch_embedconsole" Content="{loc:Tr MW.Panel.EmbedConsole}" VerticalAlignment="Center" Click="Button_EmbedConsole_Click" Margin="0,0,22,6"/>
                                        <ui:ToggleSwitch x:Name="switch_updateonstart" Content="{loc:Tr MW.Panel.UpdateOnStart}" VerticalAlignment="Center" Click="Button_UpdateOnStart_Click" Margin="0,0,22,6"/>
                                        <ui:ToggleSwitch x:Name="switch_backuponstart" Content="{loc:Tr MW.Panel.BackupOnStart}" VerticalAlignment="Center" Click="Button_BackupOnStart_Click" Margin="0,0,22,6"/>
                                        <ui:ToggleSwitch x:Name="switch_backupbeforeupdate" Content="{loc:Tr MW.Panel.BackupBeforeUpdate}" ToolTip="{loc:Tr MW.Panel.BackupBeforeUpdateTip}" VerticalAlignment="Center" Click="Button_BackupBeforeUpdate_Click" Margin="0,0,0,6"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- CARD: Scheduling -->
                            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,8" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                                        <Border Width="3" Height="15" CornerRadius="2" Background="#4CC2D6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <ui:SymbolIcon Symbol="Clock24" FontSize="15" Foreground="#4CC2D6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Tr MW.Panel.SecSchedule}" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,7">
                                        <ui:ToggleSwitch x:Name="switch_restartcrontab" Content="{loc:Tr MW.Panel.RestartCrontab}" VerticalAlignment="Center" Click="Button_RestartCrontab_Click" Margin="0,0,12,0"/>
                                        <Button x:Name="button_restartcrontabedit" Cursor="Hand" Content="{loc:Tr MW.Common.Edit}" VerticalAlignment="Center" MinWidth="60" Padding="10,3" Height="28" Click="Button_CrontabEdit_Click" Margin="0,0,8,0"/>
                                        <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textBox_restartcrontab" Height="28" TextWrapping="Wrap" Text="" IsReadOnly="true" Width="110" FontFamily="Consolas" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Orientation="Horizontal">
                                        <Label Content="{loc:Tr MW.Panel.NextRun}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBox Padding="8,2" VerticalContentAlignment="Center" x:Name="textBox_nextcrontab" Height="26" TextWrapping="Wrap" Text="" IsReadOnly="true" Width="185" FontFamily="Consolas" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- CARD: Discord alerts (enable toggle sits in the header) -->
                            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,2" Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                                        <Border Width="3" Height="15" CornerRadius="2" Background="#4CC2D6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <ui:SymbolIcon Symbol="Alert24" FontSize="15" Foreground="#4CC2D6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Tr MW.Panel.SecDiscord}" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center"/>
                                        <ui:ToggleSwitch x:Name="switch_discordalert" VerticalAlignment="Center" Click="Button_DiscordAlert_Click" Margin="14,0,0,0"/>
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal">
                                        <Button x:Name="button_discordedit" Cursor="Hand" Content="{loc:Tr MW.Common.Edit}" VerticalAlignment="Center" MinWidth="60" Padding="10,3" Height="28" Click="Button_DiscordEdit_Click" Margin="0,0,8,6"/>
                                        <Button x:Name="button_discordset" Cursor="Hand" Content="{loc:Tr MW.Panel.SetMessage}" VerticalAlignment="Center" MinWidth="110" Padding="10,3" Height="28" Click="Button_DiscordSetMessage_Click" Margin="0,0,8,6"/>
                                        <Button x:Name="button_discordsettings" Content="{loc:Tr MW.Panel.Settings}" VerticalAlignment="Center" MinWidth="95" Padding="10,3" Height="28" Click="Button_DiscordAlertSettings_Click" Margin="0,0,8,6"/>
                                        <Button x:Name="button_discordtest" Cursor="Hand" Content="{loc:Tr MW.Panel.TestAlert}" VerticalAlignment="Center" MinWidth="95" Padding="10,3" Height="28" Click="Button_DiscordWebhookTest_Click" IsEnabled="False" Margin="0,0,0,6"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                        </ScrollViewer>

                        <!-- Log fills the remaining space -->
                        <DockPanel Margin="0,6,0,0">
                            <Label x:Name="label_wgsmlog" DockPanel.Dock="Top" Content="{loc:Tr MW.Panel.Log}" HorizontalAlignment="Left"/>
                            <TextBox x:Name="textBox_wgsmlog" Margin="0,4,6,0" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True"/>
                        </DockPanel>
                    </DockPanel>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch">
                        <GridSplitter.Background>
                            <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlDarkDarkColorKey}}"/>
                        </GridSplitter.Background>
                    </GridSplitter>

                    <!-- Console = FIXED dark terminal (readable regardless of light/dark theme).
                         Style="{x:Null}" -> reverts to a classic WPF TextBox that honors Background/Foreground
                         (the WPF-UI TextBox ignores them in favor of theme brushes). -->
                    <Grid Grid.Column="2" MinWidth="100" Background="#FF1B1B1B">
                        <Rectangle Height="30" VerticalAlignment="Top" Fill="#FF2A2A2A"/>
                        <Button x:Name="Button_AutoScroll" Style="{x:Null}" Cursor="Hand" VerticalAlignment="Top" HorizontalAlignment="Left" Width="120" Content="{loc:Tr MW.Console.AutoScroll}" Background="#FF2A2A2A" Foreground="#FFEAEAEA" Height="30" BorderThickness="0" Click="Button_AutoScroll_Click" />
                        <Button x:Name="button_clearServerConsole" Style="{x:Null}" Cursor="Hand" Content="{loc:Tr MW.Common.Clear}" Height="30" Click="Button_ClearServerConsole_Click" HorizontalAlignment="Right" Width="61" VerticalAlignment="Top" Background="#FF2A2A2A" Foreground="#FFEAEAEA" BorderThickness="0" />
                        <TextBox x:Name="console" Style="{x:Null}" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility ="Disabled" Background="#FF1B1B1B" IsReadOnly="True" Margin="0,30,0,26" BorderBrush="#FF1B1B1B" Foreground="#FFEAEAEA" BorderThickness="0" SelectionBrush="#FF3399FF" TextWrapping="Wrap"/>
                        <TextBox x:Name="textbox_servercommand" Style="{x:Null}" Padding="6,3" VerticalContentAlignment="Center" TextWrapping="Wrap" Text="" Margin="0,0,61,0" Height="28" VerticalAlignment="Bottom" KeyDown="Textbox_ServerCommand_KeyDown" IsEnabled="False" Background="#FF1B1B1B" BorderBrush="#FF3A3A3A" Foreground="#FFEAEAEA" CaretBrush="#FFEAEAEA" PreviewKeyDown="Textbox_ServerCommand_PreviewKeyDown"/>
                        <Button x:Name="button_servercommand" Style="{x:Null}" Cursor="Hand" Content="{loc:Tr MW.Console.Send}" Click="Button_ServerCommand_Click" IsEnabled="False" Height="26" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="61" Background="#FF2A2A2A" Foreground="#FFEAEAEA" BorderThickness="0" />
                    </Grid>
                </Grid>
            </Grid>
        </DockPanel>

        <!-- Backups tab (backup versioning) -->
        <DockPanel Name="hMenu_Backups" Margin="190,0,0,0" Visibility="Hidden">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{loc:Tr MW.Backups.Title}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,14"/>
                <DockPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock Text="{loc:Tr MW.Backups.ServerLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ui:Button Content="{loc:Tr MW.Backups.Refresh}" Icon="{ui:SymbolIcon ArrowSync24}" DockPanel.Dock="Right" Click="Backups_Refresh_Click"/>
                    <ui:Button Content="{loc:Tr MW.Backups.BackUpAll}" Icon="{ui:SymbolIcon Save24}" DockPanel.Dock="Right" Margin="0,0,8,0" Click="Actions_BackupAll_Click"/>
                    <ComboBox x:Name="cb_backupServer" Width="280" HorizontalAlignment="Left" DisplayMemberPath="Name" SelectionChanged="Backups_ServerChanged"/>
                </DockPanel>
                <!-- Backup location (path) for the selected server: editable -->
                <DockPanel Grid.Row="2" Margin="0,0,0,12">
                    <TextBlock Text="{loc:Tr MW.Backups.FolderLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ui:Button Content="{loc:Tr MW.Backups.Change}" Icon="{ui:SymbolIcon FolderOpen24}" DockPanel.Dock="Right" Click="Backups_ChangeLocation_Click"/>
                    <ui:Button Content="{loc:Tr MW.Backups.Folders}" Icon="{ui:SymbolIcon FolderOpen24}" DockPanel.Dock="Right" Margin="0,0,8,0" Click="Backups_ChangeFolders_Click" ToolTip="{loc:Tr MW.Backups.FoldersTip}"/>
                    <TextBox x:Name="textBox_backupLocation" IsReadOnly="True" Padding="8,2" VerticalContentAlignment="Center" Margin="0,0,8,0"
                             FontFamily="Consolas" ToolTip="{loc:Tr MW.Backups.LocationTip}"/>
                </DockPanel>
                <ListView x:Name="lv_backups" Grid.Row="3" Background="{DynamicResource ApplicationBackgroundBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{loc:Tr MW.Backups.Col.Backup}" Width="400" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="{loc:Tr MW.Backups.Col.Date}" Width="170" DisplayMemberBinding="{Binding Date}"/>
                            <GridViewColumn Header="{loc:Tr MW.Backups.Col.Size}" Width="110" DisplayMemberBinding="{Binding Size}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
                <DockPanel Grid.Row="4" Margin="0,12,0,0">
                    <ui:Button Content="{loc:Tr MW.Backups.BackUpThis}" Icon="{ui:SymbolIcon Save24}" DockPanel.Dock="Left" Click="Backups_BackupNow_Click"/>
                    <ui:Button Content="{loc:Tr MW.Common.Restore}" Icon="{ui:SymbolIcon ArrowUndo24}" Margin="8,0,0,0" DockPanel.Dock="Left" Appearance="Caution" Click="Backups_Restore_Click"/>
                    <ui:Button Content="{loc:Tr MW.Common.Delete}" Icon="{ui:SymbolIcon Delete24}" Margin="8,0,0,0" DockPanel.Dock="Left" Appearance="Danger" Click="Backups_Delete_Click"/>
                    <ui:Button Content="{loc:Tr MW.Backups.OpenFolder}" Icon="{ui:SymbolIcon FolderOpen24}" Margin="8,0,0,0" DockPanel.Dock="Left" Click="Backups_OpenFolder_Click"/>
                    <!-- Scheduled backup (per server) -->
                    <ComboBox x:Name="cb_backupHour" Width="70" DockPanel.Dock="Right" VerticalAlignment="Center" SelectionChanged="BackupSchedule_Changed"/>
                    <ui:ToggleSwitch x:Name="switch_backupauto" Content="{loc:Tr MW.Backups.AutoBackupAt}" ToolTip="{loc:Tr MW.Backups.AutoBackupTip}" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,6,0" Click="BackupSchedule_Changed"/>
                </DockPanel>
            </Grid>
        </DockPanel>

        <!-- Windows 11 sidebar (replaces the Metro HamburgerMenu) - collapsible (pin/unpin) -->
        <Border x:Name="SidebarBorder" HorizontalAlignment="Left" Width="190" Panel.ZIndex="10"
                Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="8,12,8,8">
                <ui:Button x:Name="NavToggle" Icon="{ui:SymbolIcon Navigation24}" ToolTip="{loc:Tr MW.Nav.ToggleTip}" Appearance="Secondary" Click="NavToggle_Click" HorizontalAlignment="Left" Margin="0,0,0,8" Padding="10,8"/>
                <ui:Button x:Name="NavHome" Content="{loc:Tr MW.Nav.Home}" Icon="{ui:SymbolIcon Home24}" Appearance="Primary" Click="NavHome_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavDashboard" Content="{loc:Tr MW.Nav.Dashboard}" Icon="{ui:SymbolIcon DataHistogram24}" Appearance="Secondary" Click="NavDashboard_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavDiscordBot" Content="{loc:Tr MW.Nav.DiscordBot}" Icon="{ui:SymbolIcon Chat24}" Appearance="Secondary" Click="NavDiscordBot_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavBackups" Content="{loc:Tr MW.Nav.Backups}" Icon="{ui:SymbolIcon Archive24}" Appearance="Secondary" Click="NavBackups_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <Separator Margin="4,10"/>
                <ui:Button x:Name="NavPlugins" Content="{loc:Tr MW.Nav.Plugins}" Icon="{ui:SymbolIcon PuzzlePiece24}" Appearance="Secondary" Click="NavPlugins_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavSettings" Content="{loc:Tr MW.Nav.Settings}" Icon="{ui:SymbolIcon Settings24}" Appearance="Secondary" Click="NavSettings_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <Separator Margin="4,10"/>
                <ui:Button x:Name="NavPorts" Content="{loc:Tr MW.Nav.Ports}" Icon="{ui:SymbolIcon Globe24}" Appearance="Secondary" Click="Tools_PortForward_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavDoctor" Content="{loc:Tr MW.Nav.Doctor}" Icon="{ui:SymbolIcon Search24}" Appearance="Secondary" Click="Tools_ServerDoctor_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavNotifs" Content="{loc:Tr MW.Nav.Notifications}" Icon="{ui:SymbolIcon Alert24}" Appearance="Secondary" Click="Nav_Notifications_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavWebApi" Content="{loc:Tr MW.Nav.WebApi}" Icon="{ui:SymbolIcon Globe24}" Appearance="Secondary" Click="Nav_WebApi_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
            </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
    </Grid>
    </Grid>
</ui:FluentWindow>
