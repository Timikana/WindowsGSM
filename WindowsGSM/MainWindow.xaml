                <DataGrid x:Name="ServerGrid"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          RowHeaderWidth="0"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          DockPanel.Dock="Top"
                          SelectionChanged="DataGrid_SelectionChanged"
                          IsSynchronizedWithCurrentItem="True"
                          HorizontalScrollBarVisibility="Disabled"
                          CanUserSortColumns="True"
                          RowHeight="34"
                          ColumnHeaderHeight="38"
                          FontSize="13"
                          VerticalContentAlignment="Center"
                          AlternationCount="2">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" IsReadOnly="True" Binding="{Binding Path=ID}" Width="35" MinWidth="35" MaxWidth="35"/>
                        <DataGridTextColumn Header="PID" IsReadOnly="True" Binding="{Binding Path=PID}" Width="65" MinWidth="55" MaxWidth="95"/>
                        <DataGridTemplateColumn Header="MOD" IsReadOnly="True" Width="53" MinWidth="53" MaxWidth="53">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Icon}" Width="18"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Status" IsReadOnly="True" Binding="{Binding Path=Status}" Width="80" MinWidth="80" MaxWidth="80"/>
                        <DataGridTemplateColumn Header="MAJ" IsReadOnly="True" Width="44" MinWidth="44" MaxWidth="44">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse Width="12" Height="12" Fill="Orange" HorizontalAlignment="Center" VerticalAlignment="Center"
                                             ToolTip="{Binding UpdateTooltip}"
                                             Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Server Name" IsReadOnly="True" Binding="{Binding Path=Name}" Width="10*" MinWidth="105"/>
                        <DataGridTextColumn Header="IP Address" IsReadOnly="True" Binding="{Binding Path=IP}" Width="4*" MinWidth="88"/>
                        <DataGridTextColumn Header="Port" IsReadOnly="True" Binding="{Binding Path=Port}" Width="4*" MinWidth="52">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PortConflict}" Value="True">
                                            <Setter Property="Foreground" Value="OrangeRed"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="ToolTip" Value="{Binding PortConflictTooltip}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Query Port" IsReadOnly="True" Binding="{Binding Path=QueryPort}" Width="4*" MinWidth="93"/>
                        <DataGridTextColumn Header="Map" IsReadOnly="True" Binding="{Binding Path=Defaultmap}" Width="7*" MinWidth="50"/>
                        <DataGridTextColumn Header="Players" IsReadOnly="True" Binding="{Binding Path=Maxplayers}" Width="3*" MinWidth="70"/>
                        <DataGridTextColumn Header="Online Players" IsReadOnly="True" Binding="{Binding Path=Players}" Width="3*" MinWidth="70" ToolTipService.ToolTip="Connected players (A2S query)"/>
                        <DataGridTextColumn Header="CPU" IsReadOnly="True" Binding="{Binding Path=Cpu}" Width="3*" MinWidth="55"/>
                        <DataGridTextColumn Header="RAM" IsReadOnly="True" Binding="{Binding Path=Ram}" Width="3*" MinWidth="70"/>
                        <DataGridTextColumn Header="Uptime" IsReadOnly="True" Binding="{Binding Path=Uptime}" Width="4*" MinWidth="80"/>
                        <!--<DataGridTextColumn Header="RAM Usage" IsReadOnly="True" Binding="{Binding Path=RamUsage}" Width="4*"/>-->
                    </DataGrid.Columns>
                </DataGrid>
