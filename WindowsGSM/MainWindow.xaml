                        <Button x:Name="button_clearServerConsole" Style="{x:Null}" Cursor="Hand" Content="CLEAR" Height="30" Click="Button_ClearServerConsole_Click" HorizontalAlignment="Right" Width="61" VerticalAlignment="Top" Background="#FF2A2A2A" Foreground="#FFEAEAEA" BorderThickness="0" />
                        <TextBox x:Name="console" Style="{x:Null}" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility ="Disabled" Background="#FF1B1B1B" IsReadOnly="True" Margin="0,30,0,26" BorderBrush="#FF1B1B1B" Foreground="#FFEAEAEA" BorderThickness="0" SelectionBrush="#FF3399FF" TextWrapping="Wrap"/>
                        <TextBox x:Name="textbox_servercommand" Style="{x:Null}" Padding="6,3" VerticalContentAlignment="Center" TextWrapping="Wrap" Text="" Margin="0,0,61,0" Height="28" VerticalAlignment="Bottom" KeyDown="Textbox_ServerCommand_KeyDown" IsEnabled="False" Background="#FF1B1B1B" BorderBrush="#FF3A3A3A" Foreground="#FFEAEAEA" CaretBrush="#FFEAEAEA" PreviewKeyDown="Textbox_ServerCommand_PreviewKeyDown"/>
                        <Button x:Name="button_servercommand" Style="{x:Null}" Cursor="Hand" Content="Send" Click="Button_ServerCommand_Click" IsEnabled="False" Height="26" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="61" Background="#FF2A2A2A" Foreground="#FFEAEAEA" BorderThickness="0" />
                    </Grid>
                </Grid>
            </Grid>
        </DockPanel>

        <!-- Backups tab (backup versioning) -->
        <DockPanel Name="hMenu_Backups" Margin="190,0,0,0" Visibility="Hidden">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Backups" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,14"/>
                <DockPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock Text="Server:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}" DockPanel.Dock="Right" Click="Backups_Refresh_Click"/>
                    <ui:Button Content="Back up all" Icon="{ui:SymbolIcon Save24}" DockPanel.Dock="Right" Margin="0,0,8,0" Click="Actions_BackupAll_Click"/>
                    <ComboBox x:Name="cb_backupServer" Width="280" HorizontalAlignment="Left" DisplayMemberPath="Name" SelectionChanged="Backups_ServerChanged"/>
                </DockPanel>
                <!-- Backup location (path) for the selected server: editable -->
                <DockPanel Grid.Row="2" Margin="0,0,0,12">
                    <TextBlock Text="Backup folder:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ui:Button Content="Change…" Icon="{ui:SymbolIcon FolderOpen24}" DockPanel.Dock="Right" Click="Backups_ChangeLocation_Click"/>
                    <ui:Button Content="Folders…" Icon="{ui:SymbolIcon FolderOpen24}" DockPanel.Dock="Right" Margin="0,0,8,0" Click="Backups_ChangeFolders_Click" ToolTip="Limit the backup to specific subfolders of serverfiles (e.g. savegame). Empty = everything (#179)."/>
                    <TextBox x:Name="textBox_backupLocation" IsReadOnly="True" Padding="8,2" VerticalContentAlignment="Center" Margin="0,0,8,0"
                             FontFamily="Consolas" ToolTip="Location where this server's backups are stored"/>
                </DockPanel>
                <ListView x:Name="lv_backups" Grid.Row="3" Background="{DynamicResource ApplicationBackgroundBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Backup" Width="400" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Date" Width="170" DisplayMemberBinding="{Binding Date}"/>
                            <GridViewColumn Header="Size" Width="110" DisplayMemberBinding="{Binding Size}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
                <DockPanel Grid.Row="4" Margin="0,12,0,0">
                    <ui:Button Content="Back up this server" Icon="{ui:SymbolIcon Save24}" DockPanel.Dock="Left" Click="Backups_BackupNow_Click"/>
                    <ui:Button Content="Restore" Icon="{ui:SymbolIcon ArrowUndo24}" Margin="8,0,0,0" DockPanel.Dock="Left" Appearance="Caution" Click="Backups_Restore_Click"/>
                    <ui:Button Content="Delete" Icon="{ui:SymbolIcon Delete24}" Margin="8,0,0,0" DockPanel.Dock="Left" Appearance="Danger" Click="Backups_Delete_Click"/>
                    <ui:Button Content="Open folder" Icon="{ui:SymbolIcon FolderOpen24}" Margin="8,0,0,0" DockPanel.Dock="Left" Click="Backups_OpenFolder_Click"/>
                    <!-- Scheduled backup (per server) -->
                    <ComboBox x:Name="cb_backupHour" Width="70" DockPanel.Dock="Right" VerticalAlignment="Center" SelectionChanged="BackupSchedule_Changed"/>
                    <ui:ToggleSwitch x:Name="switch_backupauto" Content="Auto backup at" ToolTip="Daily automatic backup at the chosen time (stop → backup → restart)" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,6,0" Click="BackupSchedule_Changed"/>
                </DockPanel>
            </Grid>
        </DockPanel>

        <!-- Windows 11 sidebar (replaces the Metro HamburgerMenu) - collapsible (pin/unpin) -->
        <Border x:Name="SidebarBorder" HorizontalAlignment="Left" Width="190" Panel.ZIndex="10"
                Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="8,12,8,8">
                <ui:Button x:Name="NavToggle" Icon="{ui:SymbolIcon Navigation24}" ToolTip="Collapse / pin the menu" Appearance="Secondary" Click="NavToggle_Click" HorizontalAlignment="Left" Margin="0,0,0,8" Padding="10,8"/>
                <ui:Button x:Name="NavHome" Content="Home" Icon="{ui:SymbolIcon Home24}" Appearance="Primary" Click="NavHome_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavDashboard" Content="Dashboard" Icon="{ui:SymbolIcon DataHistogram24}" Appearance="Secondary" Click="NavDashboard_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavDiscordBot" Content="Discord Bot" Icon="{ui:SymbolIcon Chat24}" Appearance="Secondary" Click="NavDiscordBot_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavBackups" Content="Backups" Icon="{ui:SymbolIcon Archive24}" Appearance="Secondary" Click="NavBackups_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <Separator Margin="4,10"/>
                <ui:Button x:Name="NavPlugins" Content="Plugins" Icon="{ui:SymbolIcon PuzzlePiece24}" Appearance="Secondary" Click="NavPlugins_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavSettings" Content="Settings" Icon="{ui:SymbolIcon Settings24}" Appearance="Secondary" Click="NavSettings_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <Separator Margin="4,10"/>
                <ui:Button x:Name="NavPorts" Content="Ports / UPnP" Icon="{ui:SymbolIcon Globe24}" Appearance="Secondary" Click="Tools_PortForward_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavDoctor" Content="Server Doctor" Icon="{ui:SymbolIcon Search24}" Appearance="Secondary" Click="Tools_ServerDoctor_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavNotifs" Content="Notifications" Icon="{ui:SymbolIcon Alert24}" Appearance="Secondary" Click="Nav_Notifications_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
                <ui:Button x:Name="NavWebApi" Content="Web API" Icon="{ui:SymbolIcon Globe24}" Appearance="Secondary" Click="Nav_WebApi_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,3" Padding="10,8"/>
            </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
    </Grid>
    </Grid>
</ui:FluentWindow>
